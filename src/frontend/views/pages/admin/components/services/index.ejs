<%- include('../../../../partials/head') %>
<%- include('../../../../partials/header') %>
<main class="section is-flex-grow-1">
  <p class="title has-text-centered has-text-danger">Adicionar Categorias</p>
  <div class="columns is-centered is-multiline" id="category-container">
    <div
      class="column is-flex is-justify-content-center is-align-items-center is-narrow"
    >
      <div class="box p-0 m-0">
        <button
          class="js-modal-trigger button is-info is-dark"
          data-target="modal-category"
        >
          <span class="icon">
            <i class="fa-solid fa-plus"></i>
          </span>
        </button>
      </div>
    </div>
  </div>
  <div class="divider has-background-danger m-6"></div>
  <p class="title has-text-centered has-text-danger">Adicionar Serviços</p>
  <div class="columns is-centered is-multiline" id="service-container">
    <div
      class="column is-flex is-justify-content-center is-align-items-center is-narrow"
    >
      <div class="box p-0 m-0">
        <button
          class="js-modal-trigger button is-info is-dark"
          data-target="modal-service"
        >
          <span class="icon">
            <i class="fa-solid fa-plus"></i>
          </span>
        </button>
      </div>
    </div>
  </div>
</main>

<div id="modal-category" class="modal">
  <div class="modal-background"></div>
  <div class="modal-card">
    <form action="/category" method="POST">
      <header class="modal-card-head">
        <p class="modal-card-title">Adicionar Categoria</p>
        <button class="delete" aria-label="close" type="button"></button>
      </header>
      <section class="modal-card-body">
        <div class="field">
          <p class="control has-icons-left">
            <input class="input" type="text" name="name" placeholder="Name" />
            <span class="icon is-small is-left">
              <i class="fas fa-file-signature"></i>
            </span>
          </p>
        </div>
        <div class="field">
          <p class="control has-icons-left">
            <input
              class="input"
              type="text"
              name="description"
              placeholder="Description"
            />
            <span class="icon is-small is-left">
              <i class="fas fa-comment-dots"></i>
            </span>
          </p>
        </div>
      </section>
      <footer class="modal-card-foot">
        <div class="buttons">
          <button class="button is-success" type="submit">Save changes</button>
          <button class="button" type="button">Cancel</button>
        </div>
      </footer>
    </form>
  </div>
</div>

<div id="modal-service" class="modal">
  <div class="modal-background"></div>
  <div class="modal-card">
    <form action="/service" method="POST">
      <header class="modal-card-head">
        <p class="modal-card-title">Adicionar Serviço</p>
        <button class="delete" aria-label="close" type="button"></button>
      </header>
      <section class="modal-card-body">
        <div class="field">
          <p class="control has-icons-left">
            <input
              class="input"
              type="text"
              name="categoria"
              placeholder="Categoria"
            />
            <span class="icon is-small is-left">
              <i class="fas fa-list"></i>
            </span>
          </p>
        </div>
        <div class="field">
          <p class="control has-icons-left">
            <input class="input" type="text" name="nome" placeholder="Nome" />
            <span class="icon is-small is-left">
              <i class="fas fa-file-signature"></i>
            </span>
          </p>
        </div>
        <div class="field">
          <p class="control has-icons-left">
            <input
              class="input"
              type="text"
              name="descricao"
              placeholder="Descrição"
            />
            <span class="icon is-small is-left">
              <i class="fas fa-comment-dots"></i>
            </span>
          </p>
        </div>
        <div class="field">
          <p class="control has-icons-left">
            <input
              class="input"
              type="text"
              name="duracao"
              placeholder="Duração Ex: 00:10:00"
            />
            <span class="icon is-small is-left">
              <i class="fas fa-clock"></i>
            </span>
          </p>
        </div>
        <div class="field">
          <p class="control has-icons-left">
            <input
              class="input"
              type="text"
              name="preco"
              placeholder="Preço Ex: 10.00"
            />
            <span class="icon is-small is-left">
              <i class="fas fa-brazilian-real-sign"></i>
            </span>
          </p>
        </div>
      </section>
      <footer class="modal-card-foot">
        <div class="buttons">
          <button class="button is-success" type="submit">Save changes</button>
          <button class="button" type="button">Cancel</button>
        </div>
      </footer>
    </form>
  </div>
</div>

<script src="/public/js/hideHeroFoot.js"></script>
<script src="/public/js/insertContent.js"></script>
<script src="/public/js/modal.js"></script>
<script type="module">
  setTimeout(() => hideHeroFoot(), 100);
  const categories = await fetch("/category").then((r) => r.json());
  console.log("Categorias carregadas:", categories);
  insertContent(
    "#category-container",
    "/public/partials/category.ejs",
    categories
  );
  const services = await fetch("/service").then((r) => r.json());
  console.log("Serviços carregados:", services);
  insertContent(
    "#service-container",
    "/public/partials/service.ejs",
    services
  );
</script>
<%- include('../../../../partials/footer') %>
