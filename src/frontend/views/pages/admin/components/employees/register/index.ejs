<!-- employees/register/index.ejs -->

<%- include('../../../../../partials/head') %>
<%- include('../../../../../partials/header') %>

<main class="section is-flex-grow-1">
  <div class="container">
    <div class="columns is-centered">
      <div class="column is-half">

        <div class="box">
          <p class="title has-text-centered has-text-danger mb-5">Cadastrar Funcionário</p>

          <form action="/admin/register-employee/<%= token %>" method="POST">

            <div class="field">
              <p class="control has-icons-left">
                <input class="input" type="text" name="nome" placeholder="Nome completo" required />
                <span class="icon is-small is-left"><i class="fas fa-user"></i></span>
              </p>
            </div>

            <div class="field">
              <p class="control has-icons-left">
                <input class="input" type="text" name="cpf" placeholder="CPF (000.000.000-00)" required maxlength="14" />
                <span class="icon is-small is-left"><i class="fas fa-id-card"></i></span>
              </p>
            </div>

            <div class="field">
              <p class="control has-icons-left">
                <input class="input" type="text" name="telefone" placeholder="Telefone (opcional)" maxlength="20" />
                <span class="icon is-small is-left"><i class="fas fa-phone"></i></span>
              </p>
            </div>

            <div class="field">
              <p class="control has-icons-left">
                <input class="input" type="email" name="email" placeholder="E-mail" required />
                <span class="icon is-small is-left"><i class="fas fa-envelope"></i></span>
              </p>
            </div>

            <div class="field">
              <p class="control has-icons-left">
                <input class="input" type="password" name="senha" placeholder="Senha" required />
                <span class="icon is-small is-left"><i class="fas fa-lock"></i></span>
              </p>
            </div>

            <div class="field mt-5">
              <div class="buttons is-justify-content-space-between">
                <button type="submit" class="button is-success px-6">
                  <span class="icon"><i class="fas fa-user-plus"></i></span>
                  <span>Cadastrar</span>
                </button>
                <a href="/employees/<%= token %>" class="button is-light px-6">Cancelar</a>
              </div>
            </div>

          </form>
        </div>

      </div>
    </div>
  </div>
</main>

<script src="/public/js/hideHeroFoot.js"></script>
<script>setTimeout(() => hideHeroFoot(), 100);</script>
<%- include('../../../../../partials/footer') %>
