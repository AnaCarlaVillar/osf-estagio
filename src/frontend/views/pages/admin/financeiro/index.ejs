<!-- financeiro/index.ejs -->

<%- include('../../../partials/head') %>
<%- include('../../../partials/header') %>
<% const filtro = locals.filtro ?? ''; %>
<% const resumoPorDia = locals.resumoPorDia ?? []; %>
<main class="section is-flex-grow-1">
  <div class="container">

    <h1 class="title has-text-centered mb-5">Financeiro</h1>

    <!-- Resumo Cards -->
    <div class="columns is-multiline mb-5">

      <div class="column is-one-third">
        <div class="box has-text-centered">
          <p class="heading">Total de Agendamentos</p>
          <p class="title"><%= resumo.total_agendamentos %></p>
        </div>
      </div>

      <div class="column is-one-third">
        <div class="box has-text-centered">
          <p class="heading">Receita Confirmada (R$)</p>
          <p class="title has-text-success">
            R$ <%= Number(resumo.receita_paga).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %>
          </p>
        </div>
      </div>

      <div class="column is-one-third">
        <div class="box has-text-centered">
          <p class="heading">A Receber (R$)</p>
          <p class="title has-text-warning">
            R$ <%= Number(resumo.receita_pendente).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %>
          </p>
        </div>
      </div>

    </div>

    <!-- Botão limpar carteira -->
    <div class="has-text-right mb-3">
      <button type="button" class="button is-danger is-light" id="btn-limpar-pagos">
        <span class="icon"><i class="fa-solid fa-trash-can"></i></span>
        <span>Limpar registros pagos</span>
      </button>
    </div>

    <!-- Modal confirmação limpar -->
    <div id="modal-limpar-pagos" class="modal">
      <div class="modal-background"></div>
      <div class="modal-card">
        <form action="/financeiro/<%= token %>" method="GET">
          <input type="hidden" name="action" value="limpar" />
          <header class="modal-card-head">
            <p class="modal-card-title">Limpar carteira</p>
            <button class="delete" aria-label="close" type="button"></button>
          </header>
          <section class="modal-card-body">
            <p>Isso irá remover todos os registros com status <strong>pago</strong>.</p>
            <p class="mt-3">
              Valor da carteira:&nbsp;
              <strong class="has-text-success is-size-5">
                R$ <%= Number(resumo.receita_paga).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %>
              </strong>
            </p>
            <p class="has-text-danger mt-2">Essa ação não pode ser desfeita.</p>
          </section>
          <footer class="modal-card-foot">
            <div class="buttons">
              <button class="button is-danger" type="submit">Confirmar limpeza</button>
              <button class="button" type="button">Cancelar</button>
            </div>
          </footer>
        </form>
      </div>
    </div>

    <!-- Filtros de período -->
    <div class="buttons is-centered mb-5">
      <a href="/financeiro/<%= token %>" class="button <%= filtro === '' ? 'is-warning' : 'is-dark' %>">
        Todos
      </a>
      <a href="/financeiro/<%= token %>?filtro=dia" class="button <%= filtro === 'dia' ? 'is-warning' : 'is-dark' %>">
        <span class="icon"><i class="fa-solid fa-calendar-day"></i></span>
        <span>Hoje</span>
      </a>
      <a href="/financeiro/<%= token %>?filtro=semana" class="button <%= filtro === 'semana' ? 'is-warning' : 'is-dark' %>">
        <span class="icon"><i class="fa-solid fa-calendar-week"></i></span>
        <span>7 dias</span>
      </a>
      <a href="/financeiro/<%= token %>?filtro=mes" class="button <%= filtro === 'mes' ? 'is-warning' : 'is-dark' %>">
        <span class="icon"><i class="fa-solid fa-calendar"></i></span>
        <span>Mês</span>
      </a>
    </div>

    <!-- Abas -->
    <div class="tabs is-boxed mb-0">
      <ul>
        <li id="tab-agendamentos" class="is-active">
          <a onclick="switchTab('agendamentos')">
            <span class="icon"><i class="fa-solid fa-list"></i></span>
            <span>Agendamentos</span>
          </a>
        </li>
        <li id="tab-por-dia">
          <a onclick="switchTab('por-dia')">
            <span class="icon"><i class="fa-solid fa-calendar-days"></i></span>
            <span>Resumo por Dia</span>
          </a>
        </li>
      </ul>
    </div>

    <!-- Tabela de Agendamentos -->
    <div id="panel-agendamentos" class="box" style="border-top-left-radius:0">
      <p class="title is-5 mb-4">
        <span class="icon-text">
          <span class="icon"><i class="fa-solid fa-list"></i></span>
          <span>Agendamentos</span>
        </span>
      </p>

      <% if (agendamentos.length === 0) { %>
        <p class="has-text-centered has-text-grey">Nenhum agendamento encontrado.</p>
      <% } else { %>
      <div class="table-container">
        <table class="table is-fullwidth is-striped is-hoverable">
          <thead>
            <tr>
              <th>#</th>
              <th>Data</th>
              <th>Hora</th>
              <th>Cliente</th>
              <th>Serviço</th>
              <th>Serviço (R$)</th>
              <th>Produto</th>
              <th>Total (R$)</th>
              <th>Status</th>
              <th>Ação</th>
            </tr>
          </thead>
          <tbody>
            <% agendamentos.forEach(a => { %>
            <tr>
              <td><%= a.id %></td>
              <td><%= new Date(a.data).toLocaleDateString('pt-BR') %></td>
              <td><%= String(a.hora).substring(0, 5) %></td>
              <td><%= a.cliente_nome %></td>
              <td><%= a.servico_nome %></td>
              <td>R$ <%= a.preco %></td>
              <td>
                <% if (a.status === 'pago') { %>
                  <span class="has-text-grey"><%= a.produto_nome || '—' %></span>
                <% } else { %>
                  <form action="/financeiro/produto/<%= a.id %>/<%= token %>" method="POST">
                    <input type="hidden" name="filtro" value="<%= filtro %>" />
                    <div class="select is-small">
                      <select name="produto_id" onchange="this.form.submit()">
                        <option value="">-- Nenhum --</option>
                        <% produtos.forEach(p => { %>
                          <option value="<%= p.id %>" <%= a.produto_id === p.id ? 'selected' : '' %>><%= p.nome %> (R$ <%= Number(p.preco).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %>)</option>
                        <% }) %>
                      </select>
                    </div>
                  </form>
                <% } %>
              </td>
              <td><strong>R$ <%= a.total_valor %></strong></td>
              <td>
                <% if (a.status === 'pago') { %>
                  <span class="tag is-success"><i class="fa-solid fa-check mr-1"></i> pago</span>
                <% } else if (a.status === 'agendado') { %>
                  <span class="tag is-info is-light"><%= a.status %></span>
                <% } else { %>
                  <span class="tag is-warning is-light"><%= a.status %></span>
                <% } %>
              </td>
              <td>
                <% if (a.status !== 'pago') { %>
                  <form action="/financeiro/pagamento/<%= a.id %>/<%= token %>" method="POST">
                    <input type="hidden" name="filtro" value="<%= filtro %>" />
                    <button class="button is-success is-small" type="submit">
                      <span class="icon"><i class="fa-solid fa-money-bill-wave"></i></span>
                      <span>Confirmar</span>
                    </button>
                  </form>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>

    <!-- Resumo por Dia -->
    <div id="panel-por-dia" class="box" style="display:none; border-top-left-radius:0">
      <p class="title is-5 mb-4">
        <span class="icon-text">
          <span class="icon"><i class="fa-solid fa-calendar-days"></i></span>
          <span>Resumo por Dia</span>
        </span>
      </p>
      <% if (!resumoPorDia || resumoPorDia.length === 0) { %>
        <p class="has-text-centered has-text-grey">Nenhum registro pago encontrado.</p>
      <% } else { %>
      <div class="table-container">
        <table class="table is-fullwidth is-striped is-hoverable">
          <thead>
            <tr>
              <th>Data</th>
              <th class="has-text-centered">Cortes pagos</th>
              <th class="has-text-right">Valor do dia</th>
            </tr>
          </thead>
          <tbody>
            <% resumoPorDia.forEach(d => { %>
            <tr>
              <td><%= new Date(d.dia).toLocaleDateString('pt-BR') %></td>
              <td class="has-text-centered">
                <span class="tag is-info is-light"><%= d.total_cortes %></span>
              </td>
              <td class="has-text-right">
                <strong class="has-text-success">R$ <%= d.total_valor %></strong>
              </td>
            </tr>
            <% }) %>
          </tbody>
          <tfoot>
            <tr>
              <td><strong>Total</strong></td>
              <td class="has-text-centered">
                <strong><%= resumoPorDia.reduce((s, d) => s + Number(d.total_cortes), 0) %></strong>
              </td>
              <td class="has-text-right">
                <strong class="has-text-success">
                  R$ <%= Number(resumoPorDia.reduce((s, d) => s + parseFloat(String(d.total_valor).replace(',','.')), 0)).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %>
                </strong>
              </td>
            </tr>
          </tfoot>
        </table>
      </div>
      <% } %>
    </div>

    <!-- Botão voltar -->
    <div class="has-text-centered mt-5">
      <form action="/dashboard/<%= token %>" method="GET">
        <button class="button is-warning has-text-white" type="submit">
          <span class="icon"><i class="fa-solid fa-arrow-left"></i></span>
          <span>Voltar</span>
        </button>
      </form>
    </div>

  </div>
</main>

<script src="/public/js/hideHeroFoot.js"></script>
<script>
  setTimeout(() => hideHeroFoot(), 100);

  function switchTab(name) {
    ['agendamentos', 'por-dia'].forEach(t => {
      document.getElementById('tab-' + t).classList.toggle('is-active', t === name);
      document.getElementById('panel-' + t).style.display = t === name ? '' : 'none';
    });
  }

  document.getElementById('btn-limpar-pagos').addEventListener('click', () => {
    document.getElementById('modal-limpar-pagos').classList.add('is-active');
  });

  document.querySelectorAll('#modal-limpar-pagos .modal-background, #modal-limpar-pagos .delete, #modal-limpar-pagos .modal-card-foot .button:last-child').forEach(el => {
    el.addEventListener('click', () => {
      document.getElementById('modal-limpar-pagos').classList.remove('is-active');
    });
  });
</script>
<%- include('../../../partials/footer') %>
